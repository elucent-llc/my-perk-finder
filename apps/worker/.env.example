# Worker crons — copy vars to Railway.
# NEVER add these to apps/web. NEVER prefix with NEXT_PUBLIC_.
#
# Only TWO Railway cron services:
#   apps/worker/railway.import.json         → "0 */6 * * *"  → pnpm worker:import
#   apps/worker/railway.expire-offers.json  → "30 18 * * *" → pnpm worker:expire-offers
# Note: Railway cron is UTC-only.

NODE_ENV=production

DATABASE_URL=
DIRECT_URL=

# Shared: mock import (no network credentials required — runs all sources with mock data)
MOCK_EXTERNAL=true
DEBUG_RAW_PAGES=false

# --- Awin (optional on combined import; skipped if unset and MOCK_EXTERNAL=false) ---
AWIN_ACCESS_TOKEN=
AWIN_PUBLISHER_ID=2975213
AWIN_MEMBERSHIP_FILTER=all
AWIN_REGION_CODES=US
AWIN_PAGE_SIZE=100
AWIN_MAX_PAGES=50
AWIN_DEBUG_RAW_PAGES=false

# --- CJ (implemented; OFF on Railway combined cron until ENABLE_CJ_IN_COMBINED_IMPORT=true) ---
# Do not set these on Railway yet — leave unset to avoid accidental use.
# Local test: pnpm worker:import-cj
# CJ_ACCESS_TOKEN=
# CJ_WEBSITE_ID=
# CJ_RELATIONSHIP_STATUS=joined
# CJ_PAGE_SIZE=100
# CJ_MAX_PAGES=1
# CJ_DEBUG_RAW_PAGES=false

# --- Walmart (implemented; OFF on Railway until ENABLE_WALMART_IN_COMBINED_IMPORT=true) ---
# Needs walmart.io Consumer ID + RSA signing (not legacy labs apiKey). Do not set on Railway yet.
# Local test: pnpm worker:import-walmart
# WALMART_API_KEY=
# WALMART_PUBLISHER_ID=
# WALMART_SEARCH_TERMS=electronics,home
# WALMART_PAGE_SIZE=25
# WALMART_MAX_PAGES=1
# WALMART_DEBUG_RAW_PAGES=false
