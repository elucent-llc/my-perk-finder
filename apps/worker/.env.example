# Awin import worker — copy relevant vars to Railway myperkfinder-worker-awin-import
# NEVER add these to apps/web. NEVER prefix with NEXT_PUBLIC_.
#
# Cron schedule is NOT an env var. It lives in:
#   apps/worker/railway.import-awin.json  → deploy.cronSchedule ("30 18 * * *" = 2:30 PM EDT)
#   apps/worker/railway.expire-offers.json → deploy.cronSchedule ("30 18 * * *" = 2:30 PM EDT)
#   Note: Railway cron is UTC-only. In EST winter this fires at 1:30 PM Eastern.

NODE_ENV=production

DATABASE_URL=
DIRECT_URL=

# Mock import (no Awin token required)
MOCK_EXTERNAL=true

# Required only when MOCK_EXTERNAL=false
AWIN_ACCESS_TOKEN=
AWIN_PUBLISHER_ID=2975213

# all = API testing; joined = production publishing; notJoined = optional
AWIN_MEMBERSHIP_FILTER=all
AWIN_REGION_CODES=US
AWIN_PAGE_SIZE=100

# Save full API page payloads (per-offer RawRecords always saved)
AWIN_DEBUG_RAW_PAGES=false
