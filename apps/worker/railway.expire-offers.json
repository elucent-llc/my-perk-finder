{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm build:worker"
  },
  "deploy": {
    "startCommand": "pnpm worker:expire-offers",
    "cronSchedule": "0 16 * * *",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
