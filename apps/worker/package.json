{
  "name": "@mpf/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsup",
    "import:awin": "node dist/cli/import-awin.js",
    "expire:offers": "node dist/cli/expire-offers.js",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"(lint) @mpf/worker\"",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@mpf/affiliate": "workspace:*",
    "@mpf/db": "workspace:*",
    "@mpf/env": "workspace:*",
    "@mpf/jobs": "workspace:*",
    "@mpf/validators": "workspace:*",
    "@mpf/search": "workspace:*",
    "@mpf/types": "workspace:*",
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.28.0",
    "dotenv": "^16.4.5",
    "ioredis": "^5.11.1",
    "openai": "^4.73.0",
    "resend": "^4.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@mpf/config": "workspace:*",
    "@types/node": "^22.9.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
