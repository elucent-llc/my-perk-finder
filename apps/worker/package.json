    "@mpf/env": "workspace:*",
    "@mpf/validators": "workspace:*",
    "@mpf/types": "workspace:*",
    "@prisma/client": "^5.22.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@mpf/config": "workspace:*",
    "@types/node": "^22.9.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
