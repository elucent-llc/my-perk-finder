# ---------------------------------------------------------------------------
# MyPerkFinder — environment template. Copy to .env and adjust as needed.
# Local dev defaults match docker-compose.yml (Postgres only required).
# ---------------------------------------------------------------------------

NODE_ENV=development

# --- Required (web + workers) ---
DATABASE_URL="postgresql://mpf:mpf@localhost:5433/myperkfinder?schema=public"
DIRECT_URL="postgresql://mpf:mpf@localhost:5433/myperkfinder?schema=public"

# Public site URL (no trailing slash). Used for canonical links — NOT for secrets.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Database note (Railway) ---
# start:web runs a resilient schema sync (`@mpf/db` migrate:deploy):
#   migrate deploy → on P3005 baseline → on any failure db push --accept-data-loss
# So schema changes should not take the web service down. Prefer adding Prisma
# migrations for intentional changes; avoid ad-hoc SQL that fights the schema.

# --- Admin auth (required in production on myperkfinder-web) ---
# Generate: openssl rand -base64 32
ADMIN_AUTH_SECRET=
# Local only: open /admin without a secret. Never set in production.
# ALLOW_DEV_ADMIN_BYPASS=true

# Optional dedicated secret for hashing click IPs (falls back to ADMIN_AUTH_SECRET).
# Required in production if ADMIN_AUTH_SECRET is unset for click hashing.
CLICK_HASH_SECRET=

# --- Awin import (worker ONLY — never add to apps/web, never NEXT_PUBLIC_) ---
# Required only when MOCK_EXTERNAL=false
MOCK_EXTERNAL=true
AWIN_ACCESS_TOKEN=
AWIN_PUBLISHER_ID=2975213
# all = API testing; joined = production publishing
AWIN_MEMBERSHIP_FILTER=all
AWIN_REGION_CODES=US
AWIN_PAGE_SIZE=100
AWIN_DEBUG_RAW_PAGES=false

# --- Optional: local legacy BullMQ (NOT deployed to Railway) ---
REDIS_URL="redis://localhost:6380"

# --- Optional: email / LLM (not required for Railway MVP) ---
RESEND_API_KEY=
EMAIL_FROM="deals@myperkfinder.com"
OPENAI_API_KEY=
OPENAI_MODEL="gpt-4o-mini"

# --- Optional: debug — save full Awin API page payloads to RawRecord (per-offer rows always saved) ---
# AWIN_DEBUG_RAW_PAGES=true

# --- Optional: Meilisearch (NOT deployed on Railway MVP — Postgres search is used) ---
MEILI_HOST="http://localhost:7700"
MEILI_MASTER_KEY="mpf_dev_master_key"

# --- Railway sets automatically ---
# PORT=
# RAILWAY_PUBLIC_DOMAIN=  (do not use as substitute for NEXT_PUBLIC_SITE_URL in production)
