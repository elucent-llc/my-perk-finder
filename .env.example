# ---------------------------------------------------------------------------
# MyPerkFinder — environment template. Copy to .env and adjust as needed.
# Local dev defaults match docker-compose.yml (Postgres only required).
# ---------------------------------------------------------------------------

NODE_ENV=development

# --- Required (web + workers) ---
DATABASE_URL="postgresql://mpf:mpf@localhost:5433/myperkfinder?schema=public"
DIRECT_URL="postgresql://mpf:mpf@localhost:5433/myperkfinder?schema=public"

# Public site URL (no trailing slash). Used for canonical links — NOT for secrets.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Affiliate import (server/worker ONLY — never NEXT_PUBLIC_) ---
AWIN_ACCESS_TOKEN=
AWIN_PUBLISHER_ID=

# When true, Awin/OpenAI/Resend are mocked locally. Set false in Railway production workers.
MOCK_EXTERNAL=true

# --- Optional: local BullMQ dev (apps/worker long-running mode — NOT deployed to Railway) ---
REDIS_URL="redis://localhost:6380"

# --- Optional: email / LLM (not required for Railway MVP) ---
RESEND_API_KEY=
EMAIL_FROM="deals@myperkfinder.com"
OPENAI_API_KEY=
OPENAI_MODEL="gpt-4o-mini"

# --- Optional: admin auth (future) ---
ADMIN_AUTH_SECRET=

# --- Optional: Meilisearch (NOT deployed on Railway MVP — Postgres search is used) ---
MEILI_HOST="http://localhost:7700"
MEILI_MASTER_KEY="mpf_dev_master_key"

# --- Railway sets automatically ---
# PORT=
# RAILWAY_PUBLIC_DOMAIN=
