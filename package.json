{
  "name": "my-perk-finder",
  "version": "0.1.0",
  "private": true,
  "description": "Scalable deal discovery platform — Turborepo monorepo.",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "turbo run dev --filter=@mpf/web",
    "dev:web": "turbo run dev --filter=@mpf/web",
    "dev:all": "turbo run dev",
    "build": "pnpm db:generate && pnpm --filter @mpf/web build",
    "build:web": "pnpm db:generate && pnpm --filter @mpf/web build",
    "start": "node ./scripts/start-web.mjs",
    "start:web": "node ./scripts/start-web.mjs",
    "build:worker": "pnpm db:generate && pnpm --filter @mpf/worker build",
    "worker:import": "pnpm --filter @mpf/worker run import:all",
    "worker:import-awin": "pnpm --filter @mpf/worker run import:awin",
    "worker:import-cj": "pnpm --filter @mpf/worker run import:cj",
    "worker:import-walmart": "pnpm --filter @mpf/worker run import:walmart",
    "worker:expire-offers": "pnpm --filter @mpf/worker run expire:offers",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck --filter=@mpf/web --filter=@mpf/worker --filter=@mpf/api --filter=@mpf/admin --filter=@mpf/db --filter=@mpf/ui --filter=@mpf/validators --filter=@mpf/affiliate --filter=@mpf/types --filter=@mpf/env",
    "test": "turbo run test --filter=@mpf/validators --filter=@mpf/db --filter=@mpf/web --filter=@mpf/affiliate --filter=@mpf/api",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @mpf/db generate",
    "db:migrate": "pnpm --filter @mpf/db migrate",
    "db:migrate:deploy": "pnpm --filter @mpf/db migrate:deploy",
    "db:seed": "pnpm --filter @mpf/db seed",
    "db:studio": "pnpm --filter @mpf/db studio",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.5.0",
    "typescript": "^5.6.3"
  }
}
